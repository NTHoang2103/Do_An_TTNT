# ============================================
# .gitignore for Anomaly Detection Project
# ============================================

# ============================================
# DATA (KHÔNG PUSH - Quá lớn, upload Kaggle)
# ============================================
data/
dataset/
*.zip
*.tar.gz
*.rar

# ============================================
# RESULTS & OUTPUTS (Tạo khi training)
# ============================================
results/
checkpoints/
logs/
outputs/
runs/

# ============================================
# PYTHON
# ============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ============================================
# IDE & EDITORS
# ============================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================
# OS
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================
# TEMPORARY FILES
# ============================================
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo

# ============================================
# MODELS & WEIGHTS (Nếu quá lớn)
# ============================================
*.pth
*.pt
*.ckpt
*.h5
*.pb
*.onnx

# ============================================
# KAGGLE SPECIFIC
# ============================================
kaggle.json
.kaggle/

# ============================================
# ENVIRONMENT VARIABLES
# ============================================
.env
.env.local
.env.*.local

# ============================================
# MISC
# ============================================
*.csv
*.json
!config/*.json
!**/manifest_*.json
